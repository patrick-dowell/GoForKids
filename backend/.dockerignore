# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Local virtual environment — image builds its own
venv/

# Local SQLite databases — the image uses /data/ on a mounted volume
*.db
*.db-journal

# Local env files
.env
.env.local

# Logs and analysis output
analysis_logs/
*.log

# Local Docker volume mount (host-side persistence dir — never copied
# into the image)
data/
