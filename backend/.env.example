# Copy to .env for local dev. The backend reads these at startup.

# SQLite database path. Defaults to ./goforkids.db when unset.
GOFORKIDS_DB=goforkids.db

# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic API key for study mode narratives. Optional; the app runs without it.
ANTHROPIC_API_KEY=

# KataGo paths. Optional — when unset, the bots fall back to a stub AI
# (see app/katago/engine.py). Brew install paths are auto-detected.
KATAGO_PATH=
KATAGO_MODEL=
KATAGO_CONFIG=
KATAGO_THREADS=4
KATAGO_VISITS=100
