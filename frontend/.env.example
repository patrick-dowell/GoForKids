# Copy to .env.local for local dev overrides. Vite injects VITE_*
# variables at build time. The default falls back to localhost:8000
# when this is unset (see src/api/client.ts).
VITE_API_BASE_URL=http://localhost:8000

# Shared beta access code. When unset (local dev), the AccessGate is
# bypassed and the app loads directly. Set in Render's web env to
# enable the password prompt.
VITE_BETA_PASSWORD=

# Feedback button target. Use a mailto: or GitHub-issue URL with the
# placeholder {context} (replaced with prefilled body). When unset,
# the floating Feedback button is hidden.
# Examples:
#   mailto:you@example.com?subject=GoForKids%20feedback&body={context}
#   https://github.com/you/repo/issues/new?title=Feedback&body={context}
VITE_FEEDBACK_URL=
